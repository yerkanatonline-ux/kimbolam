# Көшіріп backend/.env жасаңыз: cp .env.example .env
# .env ешқашан git-ке қосылмайды (.gitignore-де бар).

# --- AI (Anthropic) — chat.js, essay-coach.js, goal-mission.js үшін міндетті ---
ANTHROPIC_API_KEY=

# --- Дерекқор драйвері ---
# sqlite   — локал/Docker дамыту үшін (әдепкі, ешбір сыртқы аккаунт керек емес)
# supabase — production үшін (Vercel-ге деплой еткенде осыны қойып, төмендегі
#            SUPABASE_* айнымалыларын толтырыңыз)
DB_DRIVER=sqlite

# DB_DRIVER=sqlite болғанда ғана қолданылады. Әдепкі: backend/data/local.db
SQLITE_PATH=./data/local.db

# DB_DRIVER=supabase болғанда міндетті
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- CORS ---
# Рұқсат етілген origin(дер), үтірмен бөліп. Локалда: static frontend контейнер
# порты. Production-да нақты доменіңізді қойыңыз. '*' — кез келген сайт (тек
# алғашқы сынақ үшін, продта ұсынылмайды).
ALLOWED_ORIGIN=http://localhost:8080,http://127.0.0.1:8080

# --- Локал сервер порты ---
PORT=3000
